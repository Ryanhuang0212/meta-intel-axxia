From a5669bf3847a472b35d4dde01980db8057e2f4df Mon Sep 17 00:00:00 2001
From: John Jacques <john.jacques@intel.com>
Date: Thu, 14 Oct 2021 12:01:41 -0500
Subject: [PATCH] driver core: auxiliary bus: Add Config Option

To support building out of tree modules that depend on the
auxiliary bus, add a default value to the Kconfig entry.

Upstream-Status: Pending

Signed-off-by: John Jacques <john.jacques@intel.com>
---
 drivers/base/Kconfig | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/base/Kconfig b/drivers/base/Kconfig
index 064eb52ff7e2..af7a1b6996c2 100644
--- a/drivers/base/Kconfig
+++ b/drivers/base/Kconfig
@@ -2,7 +2,8 @@
 menu "Generic Driver Options"
 
 config AUXILIARY_BUS
-	bool
+	bool "Include Auxiliary Bus Support"
+	default n
 
 config UEVENT_HELPER
 	bool "Support for uevent helper"
-- 
2.39.5

